# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real secrets.

PORT=3000
NODE_ENV=production

# Path to the sqlite file, relative to the project root.
DATABASE_PATH=./server/portfolio.db

# GitHub proxy for /api/github-repos
GITHUB_USERNAME=your_github_username
# Optional. If set, must be a personal access token with only public_repo scope.
GITHUB_TOKEN=
